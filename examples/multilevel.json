{
  "module": {
    "name": "ExampleModule",
    "const": ["s1 = 1", "s2 = 2"],
    "type": ["int", "real"],
    "var": ["x1", "x2", "x3", "x4", "x5", "x6", "x7"],
    "behav": "Top"
  },
  "processes": [
    {
      "id": "A1",
      "pre": "s1 == 1",
      "post": "x2 and x3 are derived from x1",
      "decom": "A1_detail"
    },
    {
      "id": "A3",
      "post": "x5 or x7 is derived from x3",
      "decom": "A3_detail"
    },
    {
      "id": "A33",
      "pre": "s2 == 2",
      "post": "z3 is derived from z2",
      "decom": "A33_detail"
    }
  ],
  "graphs": {
    "Top": {
      "start": "IN",
      "ends": ["OUT_X6", "OUT_X7"],
      "nodes": [
        { "id": "IN", "type": "external", "label": "Input" },
        { "id": "A1", "type": "process" },
        { "id": "A2", "type": "process" },
        { "id": "A3", "type": "process" },
        { "id": "A4", "type": "process" },
        { "id": "OUT_X6", "type": "external", "label": "Output x6" },
        { "id": "OUT_X7", "type": "external", "label": "Output x7" }
      ],
      "edges": [
        { "id": "e0", "from": "IN", "to": "A1", "data": ["x1"] },
        { "id": "e1", "from": "A1", "to": "A2", "data": ["x2"] },
        { "id": "e2", "from": "A1", "to": "A3", "data": ["x3"] },
        { "id": "e3", "from": "A2", "to": "A4", "data": ["x4"] },
        { "id": "e4", "from": "A3", "to": "A4", "data": ["x5"] },
        { "id": "e5", "from": "A4", "to": "OUT_X6", "data": ["x6"] },
        { "id": "e6", "from": "A3", "to": "OUT_X7", "data": ["x7"] }
      ]
    },
    "A1_detail": {
      "start": "A12",
      "ends": ["A13"],
      "nodes": ["A11", "A12", "A13"],
      "edges": [
        { "id": "e1", "from": "A12", "to": "A11", "data": ["y1"] },
        { "id": "e2", "from": "A11", "to": "A13", "data": ["y2"] }
      ]
    },
    "A3_detail": {
      "start": "A31",
      "ends": ["A32", "A33"],
      "nodes": ["A31", "A32", "A33"],
      "edges": [
        { "id": "e1", "from": "A31", "to": "A32", "data": ["z1"] },
        { "id": "e2", "from": "A31", "to": "A33", "data": ["z2"] }
      ]
    },
    "A33_detail": {
      "start": "A331",
      "ends": ["A332"],
      "nodes": ["A331", "A332"],
      "edges": [
        { "id": "e1", "from": "A331", "to": "A332", "data": ["d2"] }
      ]
    }
  }
}
