      "post": "z1 or z2 is selected from x3"
    },
    {
      "id": "A32",
      "inputs": ["z1"],
      "outputs": ["x5"],
      "post": "x5 is derived from z1"
    },
    {
      "id": "A331",
      "inputs": ["z2"],
      "outputs": ["d1", "d2"],
      "post": "d1 or d2 is selected from z2"
    },
    {
      "id": "A332",
      "inputs": ["d1"],
      "outputs": ["z3"],
      "post": "z3 is derived from d1"
    },
    {
      "id": "A333",
      "inputs": ["d2"],
      "outputs": ["x7"],
      "post": "x7 is derived from d2"
    }
